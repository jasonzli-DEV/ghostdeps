{
  "name": "ghostdeps",
  "version": "1.0.0",
  "description": "GitHub Action that scans PRs for hallucinated and suspicious dependencies introduced by AI coding assistants",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "lint": "eslint src/**/*.ts",
    "test": "jest",
    "test:unit": "jest --testPathPattern=src/.*\\.test\\.ts",
    "test:integration": "jest --testPathPattern=test/.*\\.test\\.ts"
  },
  "keywords": [
    "github-action",
    "security",
    "dependencies",
    "ai",
    "hallucination"
  ],
  "author": "jasonzli",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "@vercel/ncc": "^0.38.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "msw": "^2.0.11",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
